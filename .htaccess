<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect all requests to school-management/public/
    RewriteCond %{REQUEST_URI} !^/installer\.php
    RewriteCond %{REQUEST_URI} !^/INSTALLATION-GUIDE\.html
    RewriteRule ^$ school-management/public/ [L]
    RewriteRule ^(.*)$ school-management/public/$1 [L]
</IfModule>
